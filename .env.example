# Farsight Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# PostgreSQL Database Configuration
# ============================================
POSTGRES_DB=farsight
POSTGRES_USER=farsight_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================
# Backend Configuration
# ============================================
# Database URL - either set directly or it will be constructed from POSTGRES_* variables above
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://farsight_user:CHANGE_ME_SECURE_PASSWORD@postgres:5432/farsight
PYTHONPATH=/app
LOG_LEVEL=INFO

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# ============================================
# Service Ports
# ============================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
PGADMIN_PORT=5050
SWAGGER_PORT=8080

# ============================================
# pgAdmin Configuration
# ============================================
PGADMIN_EMAIL=admin@farsight.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# ============================================
# Swagger UI Configuration
# ============================================
SWAGGER_JSON_URL=http://localhost:8000/openapi.json
API_URL=http://localhost:8000/openapi.json
BASE_URL=/swagger
