# Farsight Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# PostgreSQL Database Configuration
# ============================================
POSTGRES_DB=farsight
POSTGRES_USER=farsight_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
# For scripts / uvicorn on your machine, use localhost (Postgres must be reachable on this port).
# Docker Compose builds DATABASE_URL for the backend container separately (host "postgres").
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================
# Backend Configuration
# ============================================
# Used when running the API or migrations on the host. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://farsight_user:CHANGE_ME_SECURE_PASSWORD@localhost:5432/farsight
PYTHONPATH=/app
LOG_LEVEL=INFO

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# ============================================
# Keycloak (required for docker compose + JWT)
# ============================================
# Admin console login (compose service keycloak)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN
KEYCLOAK_PORT=8080
# Hostname for browser and for backend when YOU run uvicorn on the host (not inside Docker).
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=farsight
KEYCLOAK_CLIENT_ID=farsight-backend
# MUST match the "secret" of client farsight-backend in keycloak/import/farsight-realm.json
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_MATCH_REALM_JSON
# Comma-separated origins allowed by the API (default in backend includes 5173 and 3000)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# Service Ports
# ============================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
PGADMIN_PORT=5050
# Default in docker-compose.yml is 8081 so this does not collide with Keycloak on 8080
SWAGGER_PORT=8081

# ============================================
# pgAdmin Configuration
# ============================================
PGADMIN_EMAIL=admin@farsight.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# ============================================
# Swagger UI Configuration
# ============================================
SWAGGER_JSON_URL=http://localhost:8000/openapi.json
API_URL=http://localhost:8000/openapi.json
BASE_URL=/swagger
